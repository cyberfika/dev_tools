# This is useful for libraries, but typically committing lock files is recommended

# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# Pipfile.lock

# ============================================================================
# GENERATED AND TEMPORARY FILES
# ============================================================================

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*~
*.swp
*.swo

# OS temp files
.~*
Thumbs.db
ehthumbs.db

# Logs and debugging
*.log
logs/
debug/

# Cache
.cache/
.eslintcache
.node_cache/

# PlantUML generated images (keep .puml source, ignore generated)
# Uncomment if you want to ignore generated diagrams
# *.svg
# *.png
# *.pdf

# ============================================================================
# GENERATED PROJECT OUTPUTS
# ============================================================================

# Output from the project generator
my-awesome-app/
test_web_project/
test_project/

# Generated documentation
docs/generated/*
!docs/generated/.gitkeep

# ============================================================================
# MISCELLANEOUS
# ============================================================================

# Backup files
*.bak
*.backup
*.orig

# Editor backups
*~
*.swp
*.swo
*#

# OS metadata
.DS_Store
Thumbs.db
.directory

# Python type checking
.mypy_cache/
.dmypy.json
dmypy.json

# IDE type information
.pyre/

# Package management
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ============================================================================
# KEEP THESE FILES
# ============================================================================
# Explicitly allow these important files:
#
# !.gitignore              - This file itself
# !.github/                - GitHub configuration
# !.env.example            - Template for environment variables
# !.prettierrc              - Code formatter config
# !.eslintrc               - Linter config
# !.editorconfig           - Editor config

!.gitignore
!.env.example
!.prettierrc
!.eslintrc.*
!.editorconfig

github_webstorm_token.txt

docs/
docs/**
/docs/
/docs/**

# ============================================================================
# END OF .GITIGNORE
# ============================================================================
