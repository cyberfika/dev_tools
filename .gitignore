.Trash-*

# Logs and debugging
logs/
debug/
*.log

# Cache
.cache/
.eslintcache
.node_cache/

# PlantUML generated images (keep .puml source)
# *.svg
# *.png
# *.pdf

# Generated project outputs
my-awesome-app/
test_web_project/
test_project/
docs/generated/*
!docs/generated/.gitkeep

# Editor backups
*#

# Package management
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ============================================================================
# KEEP THESE FILES
# ============================================================================
# Explicitly allow these important files:
#
# !.gitignore              - This file itself
# !.github/                - GitHub configuration
# !.env.example            - Template for environment variables
# !.prettierrc              - Code formatter config
# !.eslintrc               - Linter config
# !.editorconfig           - Editor config

!.gitignore
!.env.example
!.prettierrc
!.eslintrc.*
!.editorconfig

github_webstorm_token.txt

docs/
docs/**
/docs/
/docs/**

# ============================================================================
# END OF .GITIGNORE
# ============================================================================
