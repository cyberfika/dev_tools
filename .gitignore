.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Configuration
.config/
config.local.js
config.local.json

# Credentials and secrets (NEVER commit these!)
credentials.json
secrets.json
.credentials
private_key.pem
public_key.pem
github_token.txt
api_keys.txt

# Build and distribution
dist/
*.o
*.a
*.dylib
*.dll
*.exe
*.out
*.tsbuildinfo
.tsc-out/
webpack-stats.json

# Testing and coverage
coverage/
.nyc_output/
test-results/
junit.xml
test-report.html

# Dependency lock files (optional - uncomment to use)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*~
*.swp
*.swo

# OS files
.~*
Thumbs.db
ehthumbs.db
.DS_Store
.directory
Desktop.ini
*.cab
*.msi
*.msix
*.msapp
*.lnk
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.Icon?
.CFUserTextEncoding
