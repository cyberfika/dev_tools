# ============================================================================
# NODE.JS / NPM
# ============================================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Temporary files
*.tsbuildinfo

# Lock files (optional - uncomment if you want to ignore)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Output of the build process
dist/
build/

# ============================================================================
# IDE AND EDITOR FILES
# ============================================================================

# VS Code
.vscode/
*.code-workspace
.history/
.vscode-settings.json

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr
.DS_Store
*.sublime-workspace
*.sublime-project

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt][a-z]
Session.vim
.exrc

# Emacs
*~
\#*\#
.\#*

# Nano
.nano_history

# Sublime Text
*.sublime-workspace
*.sublime-project

