# ============================================================================
# Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file - it contains sensitive information
#
# cp .env.example .env
#
# ============================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Environment type: development, staging, production
NODE_ENV=development

# Debug mode: true or false
DEBUG=false

# ============================================================================
# PROJECT CONFIGURATION
# ============================================================================

# Project name (internal identifier)
PROJECT_NAME=my-awesome-app

# Project version
PROJECT_VERSION=1.0.0

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API base URL
VITE_API_BASE_URL=http://localhost:3000/api

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Backend authentication type: jwt, session, oauth
AUTH_TYPE=jwt

# JWT secret (backend only)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT expiration time (e.g., 24h, 7d)
JWT_EXPIRATION=24h

# OAuth provider (if using OAuth)
OAUTH_PROVIDER=google
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret

# ============================================================================
# DATABASE
# ============================================================================

# Database type: postgresql, mysql, mongodb, sqlite
DB_TYPE=postgresql

# Database connection string
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_db
DB_USER=postgres
DB_PASSWORD=postgres

# Full connection string (alternative)
# DATABASE_URL=postgresql://user:password@localhost:5432/myapp

# ============================================================================
# CACHING
# ============================================================================

# Cache type: redis, memcached, in-memory
CACHE_TYPE=redis

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTL in seconds
CACHE_TTL=3600

# ============================================================================
# PAYMENT PROCESSING
# ============================================================================

# Payment provider: stripe, paypal, square
PAYMENT_PROVIDER=stripe

# Stripe keys
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Email service: sendgrid, mailgun, ses, smtp
EMAIL_SERVICE=sendgrid

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key

# Mailgun
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=mg.yourdomain.com

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Sender email
EMAIL_FROM=noreply@yourapp.com
EMAIL_FROM_NAME=Your App Name

# ============================================================================
# FILE STORAGE
# ============================================================================

# Storage type: local, aws-s3, gcs, azure
STORAGE_TYPE=local

# Local storage path
STORAGE_PATH=./uploads

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-bucket-name

# Google Cloud Storage
GCS_PROJECT_ID=your-gcp-project
GCS_BUCKET=your-gcs-bucket

# ============================================================================
# ANALYTICS AND MONITORING
# ============================================================================

# Analytics provider: google-analytics, mixpanel, segment
ANALYTICS_PROVIDER=google-analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Error tracking: sentry, rollbar, bugsnag
ERROR_TRACKING=sentry
SENTRY_DSN=https://your-sentry-dsn

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# GitHub API token (for actions, etc)
GITHUB_TOKEN=ghp_your_github_token

# SendGrid API key
SENDGRID_API_KEY=SG.your_sendgrid_key

# ============================================================================
# SECURITY
# ============================================================================

# CORS allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# CSRF protection
CSRF_ENABLED=true

# HTTPS only (in production)
HTTPS_ONLY=false

# Session secret
SESSION_SECRET=your-super-secret-session-key

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=15m

# ============================================================================
# LOGGING
# ============================================================================

# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# Log format: json, text
LOG_FORMAT=json

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features for A/B testing
FEATURE_NEW_UI=false
FEATURE_BETA_API=false
FEATURE_DARK_MODE=true

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Mock data for development
USE_MOCK_DATA=false

# Enable request/response logging
LOG_REQUESTS=true

# Open browser automatically on start
OPEN_BROWSER=true

# ============================================================================
# NOTES
# ============================================================================

# Remember to:
# 1. Never commit the actual .env file
# 2. Update .env.example with new variables
# 3. Keep .env.example in version control
# 4. Copy .env.example to .env and fill in real values
# 5. Document each variable purpose clearly
# 6. Use different values for each environment (dev, staging, prod)
# 7. Rotate secrets regularly in production
# 8. Never hardcode sensitive values in code
